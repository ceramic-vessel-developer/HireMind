# Database Configuration
DBUSER=postgres
DBPASS=your_postgres_password
DBHOST=localhost
DBNAME=hiremind
DBPORT=5432

# JWT Secret Key
# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here

# Google Drive API
# Path to service account JSON file (download from Google Cloud Console)
SERVICE_ACCOUNT_FILE=service_account.json

# Optional: Google Drive Folder ID (for organizing uploaded CVs)
# Leave empty or remove if not organizing by folder
GOOGLE_DRIVE_FOLDER_ID=
